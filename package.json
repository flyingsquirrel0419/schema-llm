{
  "name": "schema-llm",
  "version": "1.0.1",
  "description": "Type-safe LLM response parser with Zod schema validation.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyingsquirrel0419/schema-llm.git"
  },
  "homepage": "https://github.com/flyingsquirrel0419/schema-llm#readme",
  "bugs": {
    "url": "https://github.com/flyingsquirrel0419/schema-llm/issues"
  },
  "keywords": [
    "llm",
    "ai",
    "parser",
    "zod",
    "typescript",
    "openai",
    "claude",
    "gemini",
    "streaming"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "templates"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:zod3": "npm install --no-save zod@^3.25.0 && npm run typecheck && npm test && npm run build",
    "lint": "biome check src tests templates package.json tsconfig.json tsup.config.ts vitest.config.ts biome.json README.md",
    "format": "biome format --write src tests templates package.json tsconfig.json tsup.config.ts vitest.config.ts biome.json README.md",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "zod": ">=3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@vitest/coverage-v8": "^4.1.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  }
}
